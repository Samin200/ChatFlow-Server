# ─────────────────────────────────────────────
#  ChatFlow Backend — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server port
PORT=5000

# MongoDB (Atlas: database name chatflow in path; replace YOUR_USERNAME / YOUR_PASSWORD)
MONGO_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.ke1tl7z.mongodb.net/chatflow?retryWrites=true&w=majority

# JWT signing secret — CHANGE THIS in production!
JWT_SECRET=your_super_secret

# Frontend origin for CORS (no trailing slash)
CLIENT_URL=http://localhost:5173
